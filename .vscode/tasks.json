{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: check",
      "type": "shell",
      "command": "npm.cmd",
      "args": [
        "run",
        "check"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$tsc",
      "group": "build"
    }
  ]
}
